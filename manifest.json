{
  "manifest_version": 2,
  "name": "Block Okta FastPass",
  "version": "1.0",
  "description": "Prevents Okta FastPass from auto-signing in on service account profiles. Shows the authenticator picker instead.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Block Okta FastPass"
  },
  "permissions": ["webRequest", "webRequestBlocking", "<all_urls>", "tabs"],
  "content_scripts": [{
    "matches": ["https://okta.umich.edu/*"],
    "js": ["content.js"],
    "run_at": "document_start",
    "all_frames": true
  }]
}
